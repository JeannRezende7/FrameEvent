rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leitura pública liberada (necessária para a página do QR Code).
    // Escrita é feita pelo painel admin, que usa login fixo (não Firebase Auth).
    // Para produção, recomenda-se restringir a escrita via Cloud Functions
    // ou trocar para Firebase Auth real no painel.
    match /events/{eventId} {
      allow read: if true;
      allow write: if true;

      match /frames/{frameId} {
        allow read: if true;
        allow write: if true;
      }
    }
  }
}
